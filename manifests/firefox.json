{
  "manifest_version": 2,
  "name": "BetterKnightsUI - New Look for myUCF",
  "version": "1.7",
  "description": "Makes myUCF cleaner and easier to navigate for a better course browsing experience!",
  "permissions": ["storage", "*://www.ratemyprofessors.com/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "betterknightsui@diab.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "images/popup_icon.png"
  },
  "icons": {
    "128": "images/popup_icon_128.png"
  },
  "web_accessible_resources": [
    "images/popup_icon_128.png",
    "css/webfonts/*",
    "css/fonts/*"
  ],
  "content_scripts": [
    {
      "js": [
        "scripts/browser-polyfill.min.js",
        "scripts/jquery.min.js",
        "scripts/main_script.js",
        "scripts/table_generator.js",
        "scripts/datatables.min.js",
        "scripts/rateMyProfessorAPI.js",
        "scripts/professorNameMatching.js",
        "scripts/bootstrap.min.js"
      ],
      "css": [
        "css/vendor/bootstrap.min.css",
        "css/vendor/fontawesome.min.css",
        "css/vendor/jquery.dataTables.min.css",
        "css/vendor/google-fonts.css",
        "css/style.css",
        "css/datatables.min.css"
      ],
      "matches": [
        "https://csprod-ss.net.ucf.edu/*/CSPROD/STUDENT/*",
        "https://my.ucf.edu/psp/IHPROD/EMPLOYEE/CSPROD/*"
      ],
      "match_about_blank": true,
      "all_frames": true
    }
  ],
  "background": {
    "scripts": ["scripts/browser-polyfill.min.js", "scripts/background.js"]
  }
}
